# Skopiuj ten plik jako .env i uzupelnij wartosci na produkcji.
SECRET_KEY=wstaw_tu_dlugi_losowy_ciag_znakow
DEBUG=0
ALLOWED_HOSTS=aktiv-portal.pl,www.aktiv-portal.pl
CSRF_TRUSTED_ORIGINS=https://aktiv-portal.pl,https://www.aktiv-portal.pl

# Baza danych. Domyslnie SQLite (nic nie trzeba ustawiac).
# Aby uzyc MySQL na seohost, odkomentuj ponizsze i uzupelnij:
# DB_ENGINE=mysql
# DB_NAME=nazwa_bazy
# DB_USER=uzytkownik
# DB_PASSWORD=haslo
# DB_HOST=localhost
# DB_PORT=3306

GEOCODER_USER_AGENT=AktivPortal/1.0 (kontakt: admin@aktiv-portal.pl)
